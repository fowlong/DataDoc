<Window x:Class="CaptureFlow.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CaptureFlow.App.ViewModels"
        xmlns:views="clr-namespace:CaptureFlow.App.Views"
        xmlns:controls="clr-namespace:CaptureFlow.App.Controls"
        Title="{Binding WindowTitle}"
        Width="1400" Height="900"
        MinWidth="1000" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+O" Command="{Binding OpenFolderCommand}" />
        <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportCsvCommand}" />
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}" />
        <KeyBinding Gesture="F5" Command="{Binding RunExtractionCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="{StaticResource SurfaceBrush}"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
              Padding="4,2">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Document..." Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O" />
                <MenuItem Header="Open _Folder..." Command="{Binding OpenFolderCommand}" InputGestureText="Ctrl+Shift+O" />
                <Separator />
                <MenuItem Header="_Recent Projects" ItemsSource="{Binding RecentProjects}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding Name}" />
                            <Setter Property="Command" Value="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator />
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="_Extract">
                <MenuItem Header="_Run Extraction" Command="{Binding RunExtractionCommand}" InputGestureText="F5" />
                <MenuItem Header="Run Extraction _All" Command="{Binding RunExtractionAllCommand}" />
                <Separator />
                <MenuItem Header="Export _CSV..." Command="{Binding ExportCsvCommand}" InputGestureText="Ctrl+E" />
            </MenuItem>
            <MenuItem Header="_Create">
                <MenuItem Header="Open _Create View..." Command="{Binding OpenCreateViewCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="Extract" Style="{StaticResource PrimaryButton}" Command="{Binding RunExtractionCommand}" Margin="0,0,4,0" Padding="12,4" ToolTip="Extract current document (F5)" />
                <Button Content="Extract All" Style="{StaticResource SecondaryButton}" Command="{Binding RunExtractionAllCommand}" Margin="0,0,4,0" Padding="12,4" ToolTip="Extract all loaded documents" />
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2" />
                <Button Content="Export CSV" Style="{StaticResource SecondaryButton}" Command="{Binding ExportCsvCommand}" Margin="0,0,4,0" Padding="12,4" />
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2" />
                <Button Content="Create" Style="{StaticResource ToolBarButton}" Command="{Binding OpenCreateViewCommand}" />
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="2" Margin="0" BorderThickness="0"
                    SelectedIndex="{Binding SelectedTabIndex}">

            <!-- Extract Tab -->
            <TabItem Header="Extract">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" MinWidth="200" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="400" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="280" MinWidth="220" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*" MinHeight="200" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" MinHeight="150" />
                    </Grid.RowDefinitions>

                    <!-- Left Panel: Source Files -->
                    <Border Grid.Column="0" Grid.RowSpan="3" Style="{StaticResource PanelBorder}" Margin="4">
                        <views:SourcePanel DataContext="{Binding}" />
                    </Border>

                    <GridSplitter Grid.Column="1" Grid.RowSpan="3" Width="4"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                  Background="Transparent" />

                    <!-- Center: Document Preview with Overlay -->
                    <Border Grid.Column="2" Grid.Row="0" Style="{StaticResource PanelBorder}" Margin="4">
                        <controls:DocumentPreviewCanvas DataContext="{Binding Preview}" />
                    </Border>

                    <GridSplitter Grid.Column="2" Grid.Row="1" Height="4"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                  Background="Transparent" />

                    <!-- Bottom Center: Results Grid -->
                    <Border Grid.Column="2" Grid.Row="2" Style="{StaticResource PanelBorder}" Margin="4">
                        <views:ExtractionGridPanel DataContext="{Binding ExtractionGrid}" />
                    </Border>

                    <GridSplitter Grid.Column="3" Grid.RowSpan="3" Width="4"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                  Background="Transparent" />

                    <!-- Right Panel: Properties Inspector -->
                    <Border Grid.Column="4" Grid.RowSpan="3" Style="{StaticResource PanelBorder}" Margin="4">
                        <views:PropertiesPanel DataContext="{Binding}" />
                    </Border>
                </Grid>
            </TabItem>

            <!-- Create Tab -->
            <TabItem Header="Create (PDF from Template)">
                <views:CreatePanel DataContext="{Binding Create}" />
            </TabItem>

            <!-- Templates Tab -->
            <TabItem Header="Templates">
                <views:TemplateManagerPanel DataContext="{Binding TemplateManager}" />
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           Style="{StaticResource SubHeaderText}" VerticalAlignment="Center" />
                <ProgressBar Grid.Column="1" Width="150" Height="14" Margin="8,0"
                             Value="{Binding ProgressValue}" Maximum="100"
                             Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisConverter}}" />
                <TextBlock Grid.Column="2" Text="{Binding PageInfo}"
                           Style="{StaticResource SubHeaderText}" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
