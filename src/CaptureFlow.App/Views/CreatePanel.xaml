<UserControl x:Class="CaptureFlow.App.Views.CreatePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:conv="clr-namespace:CaptureFlow.App.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Left: Controls Panel -->
        <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock Text="Create: PDF from Template" Style="{StaticResource HeaderText}" Margin="0,0,0,12" />

                    <!-- Base Document -->
                    <TextBlock Text="Base Document" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4" />
                    <TextBlock Text="Load a PDF or DOCX as the document background"
                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" TextWrapping="Wrap" />
                    <Button Content="Load Base Document..." Style="{StaticResource SecondaryButton}"
                            Command="{Binding LoadBaseDocumentCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding BaseDocumentPath}" FontSize="10" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding BaseDocumentPath}" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding BaseDocumentType}" FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,8" />

                    <!-- Merge Template -->
                    <TextBlock Text="Merge Template" FontWeight="SemiBold" FontSize="12" Margin="0,8,0,4" />
                    <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                        Use the designer to place fields, or load a saved template. Merge fields from CSV data appear as coloured placeholders.
                    </TextBlock>
                    <TextBlock FontSize="11" Margin="0,0,0,4">
                        <Run Text="Fields: " Foreground="{StaticResource TextSecondaryBrush}" />
                        <Run Text="{Binding FieldCount, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Save Template" Style="{StaticResource ToolBarButton}"
                                Command="{Binding SaveTemplateCommand}" Margin="0,0,2,0" Padding="8,4" />
                        <Button Grid.Column="1" Content="Load Template" Style="{StaticResource ToolBarButton}"
                                Command="{Binding LoadTemplateCommand}" Margin="2,0,0,0" Padding="8,4" />
                    </Grid>
                    <TextBlock Text="{Binding TemplateFilePath}" FontSize="9" TextTrimming="CharacterEllipsis"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />

                    <!-- CSV Data Source -->
                    <TextBlock Text="CSV Data Source" FontWeight="SemiBold" FontSize="12" Margin="0,8,0,4" />
                    <Button Content="Load CSV File..." Style="{StaticResource SecondaryButton}"
                            Command="{Binding LoadCsvCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding CsvFilePath}" FontSize="10" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding CsvFilePath}" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding TotalRows, StringFormat='{}{0} rows loaded'}"
                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,4" />

                    <!-- CSV Preview (compact) -->
                    <DataGrid ItemsSource="{Binding CsvPreviewTable}"
                              AutoGenerateColumns="True" IsReadOnly="True"
                              MaxHeight="120" FontSize="9"
                              AlternatingRowBackground="#F8FAFC"
                              HorizontalGridLinesBrush="#E2E8F0"
                              VerticalGridLinesBrush="#E2E8F0"
                              Margin="0,0,0,8" />

                    <!-- Row Selection -->
                    <TextBlock Text="Row Selection" FontSize="10" FontWeight="SemiBold" Margin="0,4,0,2" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <RadioButton Content="All rows" IsChecked="{Binding UseAllRows}" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <RadioButton Content="Specific rows:" IsChecked="{Binding UseSpecificRows}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBox Text="{Binding RowSelectionPattern, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding UseSpecificRows}"
                             Padding="4,3" Margin="0,2,0,2" />
                    <TextBlock Text="e.g. 1,4 or 1-4 or 1,3-5,8" FontSize="9"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />

                    <!-- Output Settings -->
                    <TextBlock Text="Output Settings" FontWeight="SemiBold" FontSize="12" Margin="0,8,0,4" />
                    <TextBlock Text="File Name Pattern" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBox Text="{Binding FileNamePattern, UpdateSourceTrigger=PropertyChanged}"
                             Padding="4,3" Margin="0,2,0,2" />
                    <TextBlock Text="Use {{RowNumber}}, {{FieldName}} tokens" FontSize="9"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />

                    <TextBlock Text="Output Directory" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                    <Grid Margin="0,2,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding OutputDirectory}" Padding="4,3" IsReadOnly="True" />
                        <Button Grid.Column="1" Content="..." Style="{StaticResource ToolBarButton}"
                                Command="{Binding SelectOutputDirectoryCommand}" Width="30" Margin="4,0,0,0" />
                    </Grid>

                    <!-- Generate -->
                    <Button Content="Generate All Documents" Style="{StaticResource PrimaryButton}"
                            Command="{Binding GenerateAllCommand}" HorizontalAlignment="Stretch" />

                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="16" Margin="0,8,0,4"
                                 Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource SubHeaderText}"
                               TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Centre: pdfme Designer (WebView2) -->
        <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="0,4,0,4">
            <Grid>
                <wv2:WebView2 x:Name="DesignerWebView"
                              Visibility="{Binding IsDesignerReady, Converter={StaticResource BoolToVis}}" />
                <Border Background="{StaticResource SurfaceBrush}"
                        Visibility="{Binding IsDesignerReady, Converter={StaticResource InvBoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Loading Document Designer..."
                                   Style="{StaticResource HeaderText}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Right: Merge Fields Panel -->
        <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="0,4,4,4"
                Width="210"
                Visibility="{Binding HasCsvHeaders, Converter={StaticResource BoolToVis}}">
            <DockPanel Margin="8">
                <TextBlock DockPanel.Dock="Top" Text="Merge Fields" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4" />
                <TextBlock DockPanel.Dock="Top" Text="Click Insert to place on document"
                           FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap" />

                <!-- Output Format Options -->
                <Border DockPanel.Dock="Top" Background="{StaticResource PanelBackgroundBrush}"
                        CornerRadius="4" Padding="6" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Output Format" FontWeight="SemiBold" FontSize="10" Margin="0,0,0,4" />

                        <!-- Font Size -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Size" FontSize="10" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding MergeFieldFontSize, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="3,2" FontSize="10" />
                        </Grid>

                        <!-- Font Colour -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Colour" FontSize="10" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding MergeFieldFontColor, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="3,2" FontSize="10"
                                     ToolTip="Hex colour for output text, e.g. #000000" />
                        </Grid>

                        <!-- Alignment -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Align" FontSize="10" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <ComboBox Grid.Column="1"
                                      SelectedValue="{Binding MergeFieldAlignment}"
                                      Padding="3,2" FontSize="10">
                                <ComboBoxItem Content="left" IsSelected="True" />
                                <ComboBoxItem Content="center" />
                                <ComboBoxItem Content="right" />
                            </ComboBox>
                        </Grid>

                        <!-- Style toggles -->
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <CheckBox FontSize="10"
                                      IsChecked="{Binding MergeFieldUnderline}"
                                      ToolTip="Underline" Margin="0,0,10,0">
                                <TextBlock Text="U" TextDecorations="Underline" />
                            </CheckBox>
                            <CheckBox FontSize="10"
                                      IsChecked="{Binding MergeFieldStrikethrough}"
                                      ToolTip="Strikethrough">
                                <TextBlock Text="S" TextDecorations="Strikethrough" />
                            </CheckBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Field List with Insert buttons -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CsvHeaders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#DBEAFE" CornerRadius="3" Padding="6,3" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding}" FontSize="11" Foreground="#1E40AF" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding}" />
                                    </Border>
                                    <Button Grid.Column="1" Content="Insert" Padding="8,2" Margin="4,0,0,0"
                                            Style="{StaticResource ToolBarButton}" FontSize="10"
                                            Command="{Binding DataContext.InsertMergeFieldCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
