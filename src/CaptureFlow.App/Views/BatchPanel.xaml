<UserControl x:Class="CaptureFlow.App.Views.BatchPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CaptureFlow.App.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: Settings & File List -->
        <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Batch Processing" Style="{StaticResource HeaderText}" Margin="0,0,0,8" />

                <!-- Folder path -->
                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                    <TextBlock Text="Folder" Style="{StaticResource SubHeaderText}" Margin="0,0,0,2" />
                    <TextBlock Text="{Binding FolderPath}" FontSize="11" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding FolderPath}" />
                </StackPanel>

                <!-- File type filters -->
                <StackPanel Grid.Row="2" Margin="0,0,0,8">
                    <TextBlock Text="Include File Types" Style="{StaticResource SubHeaderText}" Margin="0,0,0,4" />
                    <CheckBox Content="PDF" IsChecked="{Binding IncludePdf}" Margin="0,2" />
                    <CheckBox Content="DOCX" IsChecked="{Binding IncludeDocx}" Margin="0,2" />
                    <CheckBox Content="Images (PNG/JPG/TIFF/BMP)" IsChecked="{Binding IncludeImages}" Margin="0,2" />
                    <CheckBox Content="Email (EML/MSG)" IsChecked="{Binding IncludeEmail}" Margin="0,2" />
                    <CheckBox Content="Text (TXT/HTML/RTF)" IsChecked="{Binding IncludeText}" Margin="0,2" />
                </StackPanel>

                <!-- Template selection -->
                <StackPanel Grid.Row="2" Margin="0,8,0,8">
                    <TextBlock Text="Document Template" Style="{StaticResource SubHeaderText}" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding AvailableTemplates}"
                              SelectedItem="{Binding SelectedTemplate}"
                              DisplayMemberPath="Name" Padding="4,3" />
                </StackPanel>

                <!-- File list -->
                <ListBox Grid.Row="3" ItemsSource="{Binding Files}" BorderThickness="1"
                         BorderBrush="{StaticResource BorderBrush}" Margin="0,8,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding FileName}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{Binding Status}" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,0" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Actions -->
                <StackPanel Grid.Row="4" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Run Batch" Style="{StaticResource PrimaryButton}"
                                Command="{Binding RunBatchCommand}" Margin="0,0,4,0"
                                Visibility="{Binding IsProcessing, Converter={StaticResource InvBoolToVis}}" />
                        <Button Grid.Column="0" Content="Cancel" Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelBatchCommand}" Margin="0,0,4,0"
                                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}" />
                        <Button Grid.Column="1" Content="Export CSV" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ExportResultsCommand}" />
                    </Grid>

                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="16" Margin="0,8,0,4"
                                 Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}" />

                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource SubHeaderText}" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right: Results Grid -->
        <Border Grid.Column="1" Style="{StaticResource PanelBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Batch Results" Style="{StaticResource HeaderText}" Margin="0,0,0,8" />

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ResultsTable}"
                          AutoGenerateColumns="True"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True"
                          IsReadOnly="False"
                          SelectionMode="Extended"
                          AlternatingRowBackground="#F8FAFC"
                          HorizontalGridLinesBrush="#E2E8F0"
                          VerticalGridLinesBrush="#E2E8F0"
                          ClipboardCopyMode="IncludeHeader" />

                <!-- Errors -->
                <Expander Grid.Row="2" Header="{Binding ErrorCount, StringFormat='Errors ({0})'}"
                          IsExpanded="False" Margin="0,8,0,0">
                    <ListBox ItemsSource="{Binding Errors}" MaxHeight="120" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="11" Foreground="{StaticResource ErrorBrush}">
                                    <Run Text="{Binding FilePath, Mode=OneWay}" FontWeight="SemiBold" />
                                    <Run Text=": " />
                                    <Run Text="{Binding Message, Mode=OneWay}" />
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Expander>
            </Grid>
        </Border>
    </Grid>
</UserControl>
