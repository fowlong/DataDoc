<UserControl x:Class="CaptureFlow.App.Views.PropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CaptureFlow.App.Converters"
             xmlns:models="clr-namespace:CaptureFlow.Core.Models;assembly=CaptureFlow.Core">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <TextBlock Text="Properties" Style="{StaticResource HeaderText}" Margin="0,0,0,8" />

            <!-- Capture Boxes list -->
            <TextBlock Text="Capture Boxes" Style="{StaticResource SubHeaderText}" Margin="0,0,0,4" />
            <ListBox ItemsSource="{Binding CaptureBoxes}" SelectedItem="{Binding SelectedCaptureBox}"
                     BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                     MaxHeight="200" Margin="0,0,0,8">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4,2">
                            <CheckBox IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="12" />
                            <TextBlock Text="{Binding OutputHeader, StringFormat=' [{0}]'}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10" VerticalAlignment="Center" Margin="2,0,0,0" />
                            <TextBlock Text="{Binding PageIndex, StringFormat=' pg {0}'}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10" VerticalAlignment="Center" Margin="2,0,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Selected box properties -->
            <Border Visibility="{Binding SelectedCaptureBox, Converter={StaticResource NullToVis}}"
                    Background="{StaticResource PanelBackgroundBrush}" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                <StackPanel DataContext="{Binding SelectedCaptureBox}">
                    <TextBlock Text="Field Properties" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6" />

                    <TextBlock Text="Name" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" Padding="4,3" />

                    <TextBlock Text="Output Header" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                    <ComboBox IsEditable="True"
                              Text="{Binding OutputHeader, UpdateSourceTrigger=PropertyChanged}"
                              ItemsSource="{Binding DataContext.CsvHeaders, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              Margin="0,2,0,6" Padding="4,3" />

                    <TextBlock Text="Page" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBox Text="{Binding PageIndex}" Margin="0,2,0,6" Padding="4,3" IsReadOnly="True" />

                    <TextBlock Text="Extraction Mode" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                    <ComboBox SelectedValue="{Binding ExtractionMode}" Margin="0,2,0,6" Padding="4,3"
                              ItemsSource="{Binding Source={x:Static models:ExtractionModeValues.All}}" />

                    <TextBlock Text="Row Behaviour" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                    <ComboBox SelectedValue="{Binding RowTargetMode}" Margin="0,2,0,6" Padding="4,3"
                              ItemsSource="{Binding Source={x:Static models:RowTargetModeValues.All}}" />

                    <TextBlock Text="CSV Group" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                    <ComboBox IsEditable="True"
                              Text="{Binding CsvGroup, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,2,0,6" Padding="4,3"
                              ToolTip="Which CSV output this field belongs to (e.g. CSV 1, CSV 2)">
                        <ComboBoxItem Content="CSV 1" />
                        <ComboBoxItem Content="CSV 2" />
                        <ComboBoxItem Content="CSV 3" />
                    </ComboBox>

                    <TextBlock Text="Default Value" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBox Text="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" Padding="4,3" />

                    <TextBlock Text="Notes" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" Padding="4,3"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="60" />

                    <TextBlock Text="Position" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Rect.X, StringFormat='X: {0:F3}'}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Rect.Y, StringFormat='Y: {0:F3}'}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Rect.Width, StringFormat='W: {0:F3}'}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Rect.Height, StringFormat='H: {0:F3}'}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Repeat Groups -->
            <TextBlock Text="Repeat Groups" Style="{StaticResource SubHeaderText}" Margin="0,8,0,4" />
            <ListBox ItemsSource="{Binding RepeatGroups}" BorderThickness="1"
                     BorderBrush="{StaticResource BorderBrush}" MaxHeight="120">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" FontSize="12" Margin="4,2" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
