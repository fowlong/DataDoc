<UserControl x:Class="CaptureFlow.App.Views.MergePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CaptureFlow.App.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <conv:ByteArrayToImageConverter x:Key="ByteArrayToImage" />
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: Settings -->
        <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Merge: CSV to Documents" Style="{StaticResource HeaderText}" Margin="0,0,0,12" />

                    <!-- Step 1: Load CSV or use extraction results -->
                    <TextBlock Text="1. Data Source" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Load CSV File..." Style="{StaticResource SecondaryButton}"
                                Command="{Binding LoadCsvCommand}" Margin="0,0,2,0" />
                        <Button Grid.Column="1" Content="Use Results" Style="{StaticResource SecondaryButton}"
                                Command="{Binding DataContext.UseExtractionResultsInMergeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                ToolTip="Use current extraction results as data source" Margin="2,0,0,0" />
                    </Grid>
                    <TextBlock Text="{Binding CsvFilePath}" FontSize="11" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding CsvFilePath}" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding TotalRows, StringFormat='{}{0} rows loaded'}"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,8" />

                    <!-- Step 2: Load Template -->
                    <TextBlock Text="2. Document Template" FontWeight="SemiBold" FontSize="12" Margin="0,8,0,4" />
                    <Button Content="Load Template (DOCX/PDF)..." Style="{StaticResource SecondaryButton}"
                            Command="{Binding LoadTemplateCommand}" HorizontalAlignment="Left" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding TemplateFilePath}" FontSize="11" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding TemplateFilePath}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />

                    <!-- Step 3: Field Mappings -->
                    <TextBlock Text="3. Field Mappings" FontWeight="SemiBold" FontSize="12" Margin="0,8,0,4" />
                    <TextBlock Text="Map CSV headers to template placeholders {{...}}"
                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" TextWrapping="Wrap" />
                    <ItemsControl ItemsSource="{Binding FieldMappings}" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding TemplatePlaceholder}"
                                               FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text=" -> " VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0" />
                                    <ComboBox Grid.Column="2"
                                              ItemsSource="{Binding DataContext.CsvHeaders, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectedItem="{Binding CsvHeader}"
                                              FontSize="11" Padding="4,2" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Step 4: Output Settings -->
                    <TextBlock Text="4. Output Settings" FontWeight="SemiBold" FontSize="12" Margin="0,8,0,4" />

                    <TextBlock Text="Output Format" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,6">
                        <RadioButton Content="DOCX" IsChecked="True" GroupName="OutputFormat" Margin="0,0,12,0" />
                        <RadioButton Content="PDF" GroupName="OutputFormat" />
                    </StackPanel>

                    <TextBlock Text="File Name Pattern" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBox Text="{Binding FileNamePattern, UpdateSourceTrigger=PropertyChanged}"
                             Padding="4,3" Margin="0,2,0,2" />
                    <TextBlock Text="Use {{RowNumber}}, {{FieldName}} tokens" FontSize="9"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />

                    <TextBlock Text="Output Directory" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                    <Grid Margin="0,2,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding OutputDirectory}" Padding="4,3" IsReadOnly="True" />
                        <Button Grid.Column="1" Content="..." Style="{StaticResource ToolBarButton}"
                                Command="{Binding SelectOutputDirectoryCommand}" Width="30" Margin="4,0,0,0" />
                    </Grid>

                    <!-- Step 5: Annotations -->
                    <TextBlock Text="5. Annotations" FontWeight="SemiBold" FontSize="12" Margin="0,8,0,4" />
                    <TextBlock Text="Add text overlays to exported documents"
                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <ToggleButton Content="{Binding IsAnnotationMode, Converter={x:Static conv:BoolToAnnotationTextConverter.Instance}}"
                                      IsChecked="{Binding IsAnnotationMode}" Padding="8,3" Margin="0,0,4,0" />
                        <Button Content="Clear All" Style="{StaticResource ToolBarButton}"
                                Command="{Binding ClearAnnotationsCommand}" Padding="8,3" />
                    </StackPanel>

                    <!-- Annotation list -->
                    <ListBox ItemsSource="{Binding Annotations}" SelectedItem="{Binding SelectedAnnotation}"
                             MaxHeight="120" Margin="0,0,0,4"
                             BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding PageIndex, StringFormat='P{0}'}"
                                               FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                             MinWidth="80" FontSize="11" Padding="2,1" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}"
                                             Width="30" FontSize="9" Padding="2,1" VerticalAlignment="Center"
                                             Margin="4,0,0,0" ToolTip="Font size" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Remove Selected" Style="{StaticResource ToolBarButton}"
                            Command="{Binding RemoveAnnotationCommand}" Padding="8,3"
                            HorizontalAlignment="Left" Margin="0,0,0,8" />

                    <!-- Actions -->
                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Content="Preview" Style="{StaticResource SecondaryButton}"
                                Command="{Binding PreviewCommand}" HorizontalAlignment="Stretch" Margin="0,0,4,0" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Row " VerticalAlignment="Center" FontSize="11" />
                            <TextBox Text="{Binding PreviewRowIndex, UpdateSourceTrigger=PropertyChanged}"
                                     Width="36" Padding="4,2" FontSize="11" />
                        </StackPanel>
                    </Grid>
                    <Button Content="Generate All Documents" Style="{StaticResource PrimaryButton}"
                            Command="{Binding GenerateAllCommand}" HorizontalAlignment="Stretch" />

                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="16" Margin="0,8,0,4"
                                 Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource SubHeaderText}"
                               TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right: CSV Preview & Document Preview -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- CSV Data Preview -->
            <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Margin="0,0,0,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="CSV Data Preview" Style="{StaticResource HeaderText}" Margin="0,0,0,4" />
                    <DataGrid Grid.Row="1" ItemsSource="{Binding CsvPreviewTable}"
                              AutoGenerateColumns="True" IsReadOnly="True"
                              AlternatingRowBackground="#F8FAFC"
                              HorizontalGridLinesBrush="#E2E8F0"
                              VerticalGridLinesBrush="#E2E8F0"
                              FontSize="11" />
                </Grid>
            </Border>

            <!-- Document Preview -->
            <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,4,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header with row selector and page navigation -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Merged Document Preview" Style="{StaticResource HeaderText}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Row:" VerticalAlignment="Center" Margin="0,0,4,0"
                                       Style="{StaticResource SubHeaderText}" />
                            <TextBox Text="{Binding PreviewRowIndex, UpdateSourceTrigger=PropertyChanged}"
                                     Width="40" Padding="4,2" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <Button Content="Preview" Style="{StaticResource ToolBarButton}"
                                    Command="{Binding PreviewRowCommand}" Padding="8,3" />
                        </StackPanel>
                    </Grid>

                    <!-- Page navigation -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,4"
                                Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVis}}">
                        <Button Content="Prev" Style="{StaticResource ToolBarButton}"
                                Command="{Binding PreviousPageCommand}" Padding="8,3" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding PreviewPageDisplay}" VerticalAlignment="Center" FontSize="11" Margin="4,0" />
                        <Button Content="Next" Style="{StaticResource ToolBarButton}"
                                Command="{Binding NextPageCommand}" Padding="8,3" Margin="4,0,0,0" />
                    </StackPanel>

                    <!-- Preview image (click to add annotations) -->
                    <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Image x:Name="PreviewImage"
                                   Source="{Binding PreviewImage, Converter={StaticResource ByteArrayToImage}}"
                                   Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"
                                   HorizontalAlignment="Center" VerticalAlignment="Top"
                                   Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}"
                                   MouseLeftButtonDown="PreviewImage_MouseLeftButtonDown"
                                   Cursor="{Binding IsAnnotationMode, Converter={x:Static conv:BoolToCursorConverter.Instance}}" />
                            <TextBlock Text="Click 'Preview' to see a merged document preview"
                                       Style="{StaticResource SubHeaderText}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding HasPreview, Converter={StaticResource InvBoolToVis}}" />
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
