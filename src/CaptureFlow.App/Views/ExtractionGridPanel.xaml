<UserControl x:Class="CaptureFlow.App.Views.ExtractionGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CaptureFlow.App.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Extraction Results" Style="{StaticResource HeaderText}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding RowCount, StringFormat=' ({0} rows)'}" Style="{StaticResource SubHeaderText}"
                           VerticalAlignment="Center" Margin="4,0,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Add Row" Style="{StaticResource ToolBarButton}" Command="{Binding AddRowCommand}" Margin="0,0,4,0" />
                <Button Content="Clear" Style="{StaticResource ToolBarButton}" Command="{Binding ClearResultsCommand}" />
            </StackPanel>
        </Grid>

        <!-- Data Grid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding ResultsTable}"
                  AutoGenerateColumns="True"
                  CanUserAddRows="True"
                  CanUserDeleteRows="True"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  SelectionMode="Extended"
                  SelectionUnit="CellOrRowHeader"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F8FAFC"
                  HorizontalGridLinesBrush="#E2E8F0"
                  VerticalGridLinesBrush="#E2E8F0"
                  BorderThickness="1"
                  BorderBrush="{StaticResource BorderBrush}"
                  FontSize="12"
                  RowHeaderWidth="0"
                  ClipboardCopyMode="IncludeHeader"
                  Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
                    <Setter Property="Padding" Value="8,4" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <!-- Empty state -->
        <TextBlock Grid.Row="1" Text="Run extraction to see results here"
                   Visibility="{Binding HasResults, Converter={StaticResource InvBoolToVis}}"
                   Style="{StaticResource SubHeaderText}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />

        <!-- Footer -->
        <TextBlock Grid.Row="2" Margin="0,4,0,0"
                   Text="{Binding SourceFileName, StringFormat='Source: {0}'}"
                   Style="{StaticResource SubHeaderText}" />
    </Grid>
</UserControl>
